{
  "name": "@jcsolutions/sender",
  "version": "0.1.0-alpha.4",
  "description": "SDK leve e extensível para envio de SMS e OTP em Node.js com suporte a gateways angolanos.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "sms",
    "otp",
    "angola"
  ],
  "author": "Justino Contingo <justinocontingo@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Justino-code/sender.git"
  },
  "bugs": {
    "url": "https://github.com/Justino-code/sender/issues"
  },
  "homepage": "https://github.com/Justino-code/sender#readme",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:ombala": "vitest run tests/e2e/ombala.e2e.test.ts",
    "test:e2e:kambasms": "vitest run tests/e2e/kambasms.e2e.test.ts",
    "test:e2e:batch": "vitest run tests/e2e/ombala.batch.e2e.test.ts",
    "test:performance": "vitest run tests/performance",
    "test:all": "yarn test:unit && yarn test:integration && yarn test:performance",
    "prepublishOnly": "yarn build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.34"
  }
}